{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "Test.*\\.spec\\.ts$",
  "moduleDirectories": ["node_modules", "<rootDir>/../node_modules"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "<rootDir>/../node_modules/ts-jest",
      {
        "tsconfig": "<rootDir>/../tsconfig.json"
      }
    ]
  }
}
